# AgentVault Webapp Environment Variables

# Copy to .env.local for actual configuration

# In production, set values in your hosting platform

# Authentication
AGENTVAULT_POLYTICIAN_API_TOKEN=your-secure-api-token-here

# Inference Configuration
# Get your API key from https://venice.ai
VENICE_API_KEY=your-venice-api-key-here

# Local model (Ollama) endpoint
LOCAL_MODEL_ENDPOINT=http://localhost:11434
# Local model name (default: llama3)
LOCAL_MODEL_NAME=llama3

# Optional: Bittensor configuration (future)
# BITENSOR_API_URL=https://api.bittensor.com
# BITENSOR_WALLET_SEED=your-bittensor-wallet-seed
# BITENSOR_NETUID=1
