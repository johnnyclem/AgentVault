// ──────────────────────────────────────────────────────────────────────────────
//  AgentVault Canister – Candid Interface (Hardened)
// ──────────────────────────────────────────────────────────────────────────────

// ─── Shared Types ────────────────────────────────────────────────────────────

type AgentConfig = record {
  name      : text;
  agentType : text;
  version   : text;
  createdAt : int;
};

type WasmMetadata = record {
  hash              : vec nat8;
  size              : nat;
  loadedAt          : int;
  functionNameCount : nat;
};

type Memory = record {
  id         : text;
  memoryType : variant { fact : null; user_preference : null; task_result : null };
  content    : text;
  timestamp  : int;
  importance : nat8;
};

type Task = record {
  id          : text;
  description : text;
  status      : variant { pending : null; running : null; completed : null; failed : null };
  result      : opt text;
  timestamp   : int;
};

type WalletInfo = record {
  id           : text;
  agentId      : text;
  chain        : text;
  address      : text;
  registeredAt : int;
  status       : variant { active : null; inactive : null; revoked : null };
};

type TransactionAction = record {
  walletId   : text;
  action     : variant { send_funds : null; sign_message : null; deploy_contract : null };
  parameters : vec record { text; text };
  priority   : variant { low : null; normal : null; high : null };
  threshold  : opt nat;
};

type TransactionStatus = variant {
  pending   : null;
  queued    : null;
  signed    : null;
  completed : null;
  failed    : null;
};

type QueuedTransaction = record {
  id           : text;
  action       : TransactionAction;
  status       : TransactionStatus;
  result       : opt text;
  retryCount   : nat;
  scheduledAt  : opt int;
  createdAt    : int;
  signedAt     : opt int;
  completedAt  : opt int;
  errorMessage : opt text;
};

type EncryptedSecret = record {
  id         : text;
  ciphertext : vec nat8;
  iv         : vec nat8;
  tag        : vec nat8;
  algorithm  : variant { aes_256_gcm : null; chacha20_poly1305 : null };
  createdAt  : int;
};

// ─── Service ─────────────────────────────────────────────────────────────────

service : {

  // ── Bootstrap & Owner Management ─────────────────────────────────────────
  //
  //  Lifecycle:
  //    1. Call bootstrap()         – sets owner, initialises agent config.
  //    2. Call completeBootstrap() – freezes canister (no writes without unlock).
  //    3. Call manualUnlock()      – re-enable writes (owner only).
  //    4. Call freeze()            – re-freeze (owner only).
  //
  //  Principal allowlist:
  //    addAuthorizedPrincipal / removeAuthorizedPrincipal — owner only.
  //
  //  Kill-switch recovery:
  //    reviveCanister()            – resets health-check counters (owner only).

  bootstrap                : (AgentConfig) -> (variant { ok : text; err : text });
  completeBootstrap        : ()            -> (variant { ok : text; err : text });
  manualUnlock             : ()            -> (variant { ok : text; err : text });
  freeze                   : ()            -> (variant { ok : text; err : text });
  addAuthorizedPrincipal   : (principal)  -> (variant { ok : text; err : text });
  removeAuthorizedPrincipal: (principal)  -> (variant { ok : text; err : text });
  reviveCanister           : ()            -> (variant { ok : text; err : text });

  // ── Security & Health Queries ─────────────────────────────────────────────

  getSecurityStatus : () -> (record {
    owner             : text;
    frozenMode        : bool;
    bootstrapComplete : bool;
    canisterKilled    : bool;
    authorizedCount   : nat;
    heapBytes         : nat;
  }) query;

  getHealthStatus : () -> (record {
    alive               : bool;
    killed              : bool;
    lastCheckNs         : int;
    consecutiveTimeouts : nat;
    totalChecks         : nat;
    lastStatus          : text;
  }) query;

  // ── Transaction Queue (Phase 5B) ─────────────────────────────────────────

  queueTransaction             : (TransactionAction) -> (variant { ok : text; err : text });
  getQueuedTransactions        : ()                  -> (vec QueuedTransaction) query;
  getPendingTransactions       : ()                  -> (vec QueuedTransaction) query;
  getQueuedTransactionsByWallet: (text)              -> (vec QueuedTransaction) query;
  getQueuedTransaction         : (text)              -> (opt QueuedTransaction) query;
  markTransactionSigned        : (text, text)        -> (variant { ok : text; err : text });
  markTransactionCompleted     : (text, text)        -> (variant { ok : text; err : text });
  markTransactionFailed        : (text, text)        -> (variant { ok : text; err : text });
  retryTransaction             : (text)              -> (variant { ok : text; err : text });
  scheduleTransaction          : (text, int)         -> (variant { ok : text; err : text });
  clearCompletedTransactions   : ()                  -> (text);
  getTransactionQueueStats     : () -> (record {
    total : nat; pending : nat; queued : nat; signed : nat; completed : nat; failed : nat;
  }) query;

  // ── Wallet Registry (Phase 5A) ────────────────────────────────────────────

  registerWallet    : (WalletInfo) -> (variant { ok : text; err : text });
  getWallet         : (text)       -> (opt WalletInfo) query;
  listWallets       : (text)       -> (vec WalletInfo) query;
  deregisterWallet  : (text)       -> (variant { ok : text; err : text });
  updateWalletStatus: (text, variant { active : null; inactive : null; revoked : null })
                                   -> (variant { ok : text; err : text });

  // ── VetKeys Encrypted Secrets (Phase 5D) ─────────────────────────────────

  storeEncryptedSecret     : (EncryptedSecret) -> (variant { ok : text; err : text });
  getEncryptedSecret       : (text)            -> (opt EncryptedSecret) query;
  listEncryptedSecrets     : ()                -> (vec EncryptedSecret) query;
  deleteEncryptedSecret    : (text)            -> (variant { ok : text; err : text });
  verifyThresholdSignature : (text, text)      -> (variant { ok : text; err : text }) query;
  deriveVetKeysKey         : (text, nat)       -> (variant { ok : text; err : text });
  getVetKeysStatus         : () -> (record {
    enabled : bool; thresholdSupported : bool;
    mode    : variant { mock : null; production : null };
  }) query;

  // ── System ────────────────────────────────────────────────────────────────

  getCanisterStatus : () -> (record {
    status     : variant { running : null; stopping : null; stopped : null };
    memorySize : nat;
    cycles     : nat;
  }) query;

  getMetrics : () -> (record {
    uptime : int; operations : nat; lastActivity : int;
  }) query;
}
